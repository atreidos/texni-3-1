# Скопируйте в .env и подставьте значения из Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Sentry: Client Keys (DSN) из Settings → Projects → [проект] → Client Keys
# Без переменной SDK не инициализируется — локально можно не задавать.
# VITE_SENTRY_DSN=https://...@....ingest.de.sentry.io/...
# Опционально: true только для отладки (стек в UI). В production не задавать.
# VITE_SHOW_ERRORS=true
